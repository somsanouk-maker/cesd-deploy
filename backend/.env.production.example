# Copy to backend/.env on the server and fill in the blanks. This is the
# production counterpart of backend/.env.example — see the deploy guide for
# how each value is generated (APP_KEY, DB_PASSWORD, MAIL_* credentials).

APP_NAME=CESD
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.cesd.fe-nuol.edu.la

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

FRONTEND_URL=https://cesd.fe-nuol.edu.la
SANCTUM_STATEFUL_DOMAINS=cesd.fe-nuol.edu.la
SESSION_DOMAIN=.fe-nuol.edu.la

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Matches the `db` service in docker-compose.yml — host is the Compose
# service name, not localhost, since backend and db are separate containers.
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=cesd
DB_USERNAME=cesd
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# Real SMTP credentials — MAIL_MAILER=log (the local-dev default) only
# writes emails to a log file, so notifications never actually arrive
# unless this is a real transactional-mail provider (e.g. your
# university's SMTP relay, or a service like Postmark/SES/Mailgun).
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=cesd@fe-nuol.edu.la
MAIL_FROM_NAME="${APP_NAME}"
