# Read automatically by `docker compose` (must be named ".env", in the same
# directory as docker-compose.yml). Copy to .env and fill in real values —
# .env is gitignored, this .example file is the only one committed.

DB_DATABASE=cesd
DB_USERNAME=cesd
DB_PASSWORD=change-me-to-a-long-random-password

# Public backend URL — baked into the frontend's JS bundle at build time,
# so it must be set here (not just in backend/.env) whenever you rebuild.
NEXT_PUBLIC_API_URL=https://api.cesd.fe-nuol.edu.la
